# =============================================
# ECS-2 (172.16.0.21) 环境变量配置
# 使用方法：
#   cp .env.example .env
#   vi .env  # 填入实际密码
#
# 密码来源：执行完 02-setup-passwords.sh 后
#   grep 'kibana_system' /data/elasticsearch/passwords.txt
#   grep 'elastic '      /data/elasticsearch/passwords.txt
# =============================================

KIBANA_PASSWORD=请替换为kibana_system的实际密码
ELASTIC_PASSWORD=请替换为elastic的实际密码
